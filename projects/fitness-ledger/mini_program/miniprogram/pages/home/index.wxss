.home-page { padding-top: 24rpx; }
.home-hero { position: relative; overflow: hidden; min-height: 330rpx; padding: 42rpx 34rpx 34rpx; border-radius: 12rpx 56rpx 56rpx 56rpx; color: #f8f5ed; background: radial-gradient(circle at 84% 14%, rgba(255,218,110,.22), transparent 34%), linear-gradient(145deg, #161614, #292824); box-shadow: 0 5rpx 8rpx rgba(0,0,0,.16), 0 30rpx 64rpx rgba(35,30,21,.18); }
.home-hero::after { content: "FL / 01"; position: absolute; right: 30rpx; bottom: 28rpx; color: rgba(255,255,255,.28); font-size: 18rpx; letter-spacing: 5rpx; }
.hero-label { color: rgba(248,245,237,.62); }
.hero-title { margin-top: 28rpx; font-size: 82rpx; color: #fffaf0; }
.hero-copy { width: 78%; margin-top: 24rpx; color: rgba(248,245,237,.72); font-size: 24rpx; line-height: 1.6; }
.home-hero .readonly { background: #f8f5ed; color: #171714; }
.area-stage { position: relative; z-index: 2; margin: -8rpx 12rpx 0; padding: 36rpx 24rpx 26rpx; border-radius: 0 0 38rpx 38rpx; background: rgba(253,250,243,.95); box-shadow: 0 18rpx 44rpx rgba(53,44,29,.08); }
.stage-head { display: flex; align-items: flex-end; justify-content: space-between; padding: 0 4rpx 24rpx; }
.stage-meta { color: #918b80; font-size: 20rpx; }
.area-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14rpx; }
.area-card { position: relative; overflow: hidden; min-height: 168rpx; box-sizing: border-box; padding: 20rpx; border: 1rpx solid rgba(23,23,20,.09); border-radius: 24rpx; box-shadow: 0 4rpx 8rpx rgba(53,44,29,.05), 0 14rpx 28rpx rgba(53,44,29,.07), inset 0 2rpx 0 rgba(255,255,255,.65); }
.area-card:active { transform: translateY(2rpx) scale(.99); box-shadow: 0 3rpx 8rpx rgba(53,44,29,.08); }
.area-arms { grid-column: 1 / -1; min-height: 132rpx; }
.area-index { position: absolute; right: 18rpx; top: 16rpx; opacity: .36; font-family: serif; font-size: 26rpx; }
.area-cn { font-family: "Songti SC", serif; font-size: 50rpx; }
.area-en { margin-top: 2rpx; font-size: 17rpx; font-weight: 650; letter-spacing: 3rpx; }
.area-stats { margin-top: 22rpx; font-size: 21rpx; opacity: .72; }
.tone-amber { background: linear-gradient(145deg, #ffe39a, #e9bd45); }
.tone-coral { background: linear-gradient(145deg, #f7d5cb, #e9a997); }
.tone-teal { background: linear-gradient(145deg, #d8ebe6, #9dc9bf); }
.tone-violet { background: linear-gradient(145deg, #e8e0f4, #c8b6df); }
.tone-cyan { background: linear-gradient(120deg, #d9edf0, #add4dd); }
.latest-strip { margin-top: 26rpx; padding: 28rpx 26rpx; border-top: 1rpx solid rgba(23,23,20,.18); border-bottom: 1rpx solid rgba(23,23,20,.12); }
.latest-main { margin-top: 8rpx; font-family: "Songti SC", serif; font-size: 42rpx; }
.latest-signals { display: flex; gap: 24rpx; margin-top: 14rpx; color: #77736b; font-variant-numeric: tabular-nums; }
.quick-links { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12rpx; margin-top: 16rpx; }
.quick-link { padding: 22rpx; border-radius: 18rpx; background: rgba(239,233,221,.72); text-align: center; font-size: 23rpx; }
