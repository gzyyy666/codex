<view class="page home-page">
  <view class="home-hero">
    <view class="eyebrow hero-label">PRIVATE TRAINING ARCHIVE</view>
    <view class="title hero-title">今天练什么？</view>
    <view class="hero-copy">选部位，马上回看常用动作与最近表现。</view>
    <view class="readonly">只读 · 最近同步</view>
  </view>

  <view wx:if="{{error}}" class="inline-notice error">{{error}}</view>
  <view class="area-stage">
    <view class="stage-head"><view><view class="eyebrow">CHOOSE A BODY AREA</view><view class="section-title">今天可能练</view></view><view class="stage-meta">点按切换</view></view>
    <scroll-view scroll-x class="area-scroll" enhanced show-scrollbar="false">
      <view class="area-strip">
        <view wx:for="{{areas}}" wx:key="id" class="area-chip tone-{{item.tone}} {{selected === item.id ? 'active' : ''}}" data-part="{{item.id}}" bindtap="selectArea">
          <view class="area-cn">{{item.cn}}</view><view class="area-en">{{item.en}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{syncNotice}}" class="inline-notice">{{syncNotice}}</view>
  <view wx:if="{{actionLoading}}" class="compact-state">正在读取动作…</view>
  <block wx:elif="{{area}}">
    <view class="area-summary tone-{{areas[0].tone}}">
      <view><view class="eyebrow">{{area.labelEn}} / QUICK VIEW</view><view class="summary-name">{{area.label}}部档案</view></view>
      <view class="summary-stats"><text>{{area.latest_date || '暂无日期'}}</text><text>{{area.session_count}} 次 · {{area.movement_count}} 动作</text></view>
    </view>
    <view class="featured-head"><view><view class="eyebrow">MOST USED</view><view class="section-title">高频动作</view></view><view class="view-all" bindtap="viewAll">查看全部 →</view></view>
    <view wx:if="{{!featured.length}}" class="compact-state">当前部位暂无训练记录</view>
    <view wx:for="{{featured}}" wx:key="movement_id" class="featured-card" data-id="{{item.movement_id}}" bindtap="openMovement">
      <view class="feature-top"><view><view class="feature-name">{{item.display_name}}</view><view class="feature-en">{{item.english_name}}</view></view><view class="session-badge">{{item.sessions}} 次</view></view>
      <view class="recent-row" wx:if="{{item.latest}}"><text>{{item.latest.date}}</text><text>{{item.latest.max_weight ? item.latest.max_weight + ' kg' : '自重'}} · {{item.latest.total_reps || '-'}} reps · {{item.latest.volume || '-'}} volume</text></view>
      <view class="recent-row quiet" wx:if="{{item.previous}}"><text>上一次</text><text>{{item.previous.max_weight ? item.previous.max_weight + ' kg' : '自重'}} · {{item.previous.total_reps || '-'}} reps</text></view>
      <view class="feature-action">查看动作轨迹 →</view>
    </view>
  </block>

  <view class="quick-links"><view class="quick-link" bindtap="today">最近一日</view><view class="quick-link" bindtap="search">全库搜索</view></view>
</view>
