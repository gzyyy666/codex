<view class="page">
  <view class="eyebrow">PRIVATE FITNESS ARCHIVE</view>
  <view class="title">随身查看，<br/>不改动记录。</view>
  <view class="readonly">只读副本</view>
  <view wx:if="{{loading}}" class="state">正在读取最近同步数据…</view>
  <view wx:elif="{{error}}" class="state error">{{error}}</view>
  <view wx:elif="{{latest}}" class="card">
    <view class="eyebrow">LATEST / {{latest.date}}</view>
    <view class="metric">{{latest.body['Weight (kg)'] || '-'}} kg</view>
    <view class="row"><text>训练</text><text>{{latest.body.Training || '未记录'}}</text></view>
    <view class="row"><text>热量</text><text>{{latest.diet['Calories (kcal)'] || '-'}} kcal</text></view>
  </view>
  <view class="button" bindtap="today">查看今日</view>
  <view class="button secondary" bindtap="reference">训练前参考</view>
  <view class="button secondary" bindtap="search">搜索动作与记录</view>
</view>
