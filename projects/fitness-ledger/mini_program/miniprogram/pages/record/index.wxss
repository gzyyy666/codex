.record-section { margin-top: 20rpx; padding: 27rpx; border: 1rpx solid rgba(23,23,20,.11); border-radius: 28rpx 28rpx 7rpx 28rpx; box-shadow: 0 3rpx 6rpx rgba(53,44,29,.04), 0 16rpx 34rpx rgba(53,44,29,.06), inset 0 2rpx 0 rgba(255,255,255,.7); }
.body-section { background: linear-gradient(145deg, #f4dfd0, #efb89f); }
.diet-section { background: linear-gradient(145deg, #f7efcf, #e9d594); }
.training-section { background: linear-gradient(145deg, #dce9e4, #aecfc4); }
.record-head { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 20rpx; }
.expand { padding: 9rpx 0 5rpx; border-bottom: 1rpx solid currentColor; font-size: 21rpx; }
.record-line { display: grid; grid-template-columns: 92rpx 1fr; gap: 18rpx; padding: 15rpx 0; border-bottom: 1rpx solid rgba(23,23,20,.11); font-size: 23rpx; }
.record-line text:last-child { text-align: right; }
.macro-line { display: flex; flex-direction: column; gap: 7rpx; padding: 16rpx; border-radius: 17rpx; background: rgba(255,255,255,.28); font-variant-numeric: tabular-nums; }
.macro-line text:first-child { font-family: serif; font-size: 36rpx; }
.macro-line text:last-child { font-size: 21rpx; }
.detail-text { margin-top: 18rpx; white-space: pre-wrap; font-size: 24rpx; line-height: 1.65; }
.training-note { margin-top: 18rpx; padding-top: 18rpx; border-top: 1rpx solid rgba(23,23,20,.12); font-size: 23rpx; line-height: 1.6; }
.training-session-only { background:#fcf9f2; border-radius:10rpx 36rpx 36rpx 36rpx; }.session-title { margin-top:10rpx; font-family:"Songti SC",serif; font-size:42rpx; line-height:1.25; }.session-summary { margin-top:18rpx; color:#716b60; font-size:21rpx; line-height:1.6; }.session-empty { margin:28rpx 0 2rpx; }.training-action-card { margin-top:20rpx; padding:20rpx 0 2rpx; border-top:1rpx solid rgba(23,23,20,.13); }.training-action-card.is-link:active { opacity:.62; transform:translateY(2rpx); }.action-head { display:flex; align-items:baseline; gap:16rpx; }.action-order { flex:none; color:#93702d; font-family:serif; font-size:23rpx; }.action-name { flex:1; font-family:"Songti SC",serif; font-size:31rpx; line-height:1.35; }.action-link { color:#716b60; font-size:19rpx; }.action-meta { margin:7rpx 0 0 2rpx; color:#817b72; font-size:19rpx; }.action-set { margin:13rpx 0 0 2rpx; color:#34312c; font-size:24rpx; line-height:1.6; font-variant-numeric:tabular-nums; }.action-empty { margin:15rpx 0 0 2rpx; color:#817b72; font-size:21rpx; }.action-notes { margin:16rpx 0 0 2rpx; padding:14rpx 16rpx; border-radius:10rpx; background:#f1ece1; color:#625c51; font-size:21rpx; line-height:1.6; }.action-notes view { margin-bottom:4rpx; color:#817b72; font-size:17rpx; letter-spacing:1rpx; }.session-notes { margin-top:22rpx; color:#5d594f; white-space:pre-wrap; font-size:23rpx; line-height:1.65; }.note-label { margin-bottom:8rpx; color:#817b72; font-size:18rpx; font-weight:700; letter-spacing:2rpx; }
