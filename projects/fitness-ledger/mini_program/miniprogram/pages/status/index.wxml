<view class="page status-page"><view class="eyebrow">LOCAL-FIRST / READ ONLY</view><view class="title">同步与档案。</view>
  <view wx:if="{{loading}}" class="state">检查中…</view><view wx:elif="{{error}}" class="state error">{{error}}</view>
  <view wx:if="{{status}}" class="status-slab"><view class="status-dot"></view><view class="eyebrow">REPLICA STATUS</view><view class="status-title">只读副本已连接</view><view class="row"><text>最后同步</text><text>{{status.generated_at}}</text></view><view class="row"><text>最新记录</text><text>{{status.latest_record_date}}</text></view><view class="row"><text>数据结构</text><text>{{status.schema}}</text></view></view>
  <view class="archive-entry" bindtap="openBody"><view><view class="eyebrow">SECONDARY ARCHIVE</view><view class="section-title">身体记录</view><view class="muted">体重、排便、训练与有氧</view></view><view class="entry-arrow">→</view></view>
  <view class="archive-entry diet-entry" bindtap="openDiet"><view><view class="eyebrow">SECONDARY ARCHIVE</view><view class="section-title">饮食记录</view><view class="muted">热量、三大营养素与餐食便签</view></view><view class="entry-arrow">→</view></view>
  <view class="debug-card"><view class="eyebrow">ACCESS DIAGNOSTICS / NO PRIVATE DATA</view><view class="row"><text>权限</text><text>{{identity.openid ? '已识别账号' : '未识别'}}</text></view><view class="row"><text>OpenID</text><text selectable="true" class="debug-value">{{identity.openid || '未获取'}}</text></view><view class="row"><text>Environment</text><text selectable="true" class="debug-value">{{identity.env || '当前部署环境'}}</text></view></view>
</view>
