.status-slab { position: relative; margin-top: 26rpx; padding: 28rpx; border-radius: 10rpx 36rpx 36rpx 36rpx; color: #f8f5ed; background: linear-gradient(145deg, #1a1a18, #292824); box-shadow: 0 5rpx 8rpx rgba(0,0,0,.15), 0 24rpx 50rpx rgba(35,30,21,.16); }
.status-slab .eyebrow { color: rgba(248,245,237,.55); }
.status-slab .row { border-color: rgba(255,255,255,.14); font-size: 21rpx; }
.status-dot { position: absolute; right: 26rpx; top: 26rpx; width: 17rpx; height: 17rpx; border-radius: 50%; background: #6ece9d; box-shadow: 0 0 0 8rpx rgba(110,206,157,.12); }
.status-title { margin: 12rpx 0 18rpx; font-family: "Songti SC", serif; font-size: 42rpx; }
.archive-entry { display: flex; align-items: center; justify-content: space-between; margin-top: 18rpx; padding: 25rpx; border-radius: 26rpx 8rpx 26rpx 26rpx; background: linear-gradient(145deg, #f6c4ac, #ee8e69); box-shadow: 0 4rpx 8rpx rgba(53,44,29,.05), 0 16rpx 34rpx rgba(53,44,29,.08); }
.archive-entry:active { transform: translateY(2rpx); }
.diet-entry { background: linear-gradient(145deg, #fff0bd, #e7ca70); }
.archive-entry .section-title { margin-top: 7rpx; }
.archive-entry .muted { margin-top: 7rpx; color: rgba(23,23,20,.68); font-size: 20rpx; }
.entry-arrow { font-size: 36rpx; }
.debug-card { margin-top: 24rpx; padding: 24rpx 4rpx; border-top: 1rpx solid rgba(23,23,20,.16); }
.debug-card .row { font-size: 20rpx; }
.debug-value { max-width: 430rpx; overflow-wrap: anywhere; text-align: right; color: #77736b; }
