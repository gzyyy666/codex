.reference-page { position: relative; overflow: hidden; min-height: 100vh; }
.selected-theme { transition: background-color .25s ease; }
.tone-page-amber { background: #f8edcf; }
.tone-page-coral { background: #f8e6df; }
.tone-page-teal { background: #e4f0ed; }
.tone-page-violet { background: #eee8f5; }
.tone-page-cyan { background: #e5f1f3; }
.theme-art { position: absolute; z-index: 0; top: 220rpx; right: -230rpx; width: 780rpx; height: 1080rpx; opacity: .12; pointer-events: none; }
.part-hero, .part-switch, .sort-rail, .movement-list, .state { position: relative; z-index: 1; }
.reference-notepad-dock { position:fixed; top:calc(env(safe-area-inset-top) + 14rpx); right:22rpx; left:22rpx; z-index:20; pointer-events:none; }
.notepad-sticky { position:sticky; top:0; z-index:3; padding-top:1rpx; background:inherit; }.notepad-card { min-height:360rpx; animation:notepad-reveal .2s ease-out; }.neutral-notepad { border:1rpx solid rgba(55,51,43,.2); background:#fcf9f2; }.notepad-observer-anchor { position:relative; z-index:1; width:100%; height:2px; }.notepad-title { position:relative; z-index:1; margin-top:18rpx; font-family:"Songti SC",serif; font-size:42rpx; }.notepad-input { position:relative; z-index:1; display:block; box-sizing:border-box; width:100%; min-height:142rpx; margin-top:16rpx; padding:14rpx 0; border-top:1rpx solid rgba(23,23,20,.17); border-bottom:1rpx solid rgba(23,23,20,.12); background:transparent; color:#27251f; font-size:25rpx; line-height:1.55; }.notepad-actions { position:relative; z-index:1; display:flex; gap:28rpx; margin-top:15rpx; font-size:21rpx; font-weight:650; }.notepad-clear { color:#8b493d; }.notepad-status { position:relative; z-index:1; margin-top:10rpx; color:#8a6a14; font-size:17rpx; letter-spacing:1rpx; }@keyframes notepad-reveal { from { opacity:.35; transform:rotateX(-4deg); } to { opacity:1; transform:rotateX(0); } }
.intro { max-width: 620rpx; margin-top: 20rpx; color: #77736b; font-size: 25rpx; line-height: 1.65; }
.freshness { margin-top: 18rpx; color: #77736b; font-size: 19rpx; letter-spacing: 1rpx; }
.freshness::before { content: ""; display: inline-block; width: 12rpx; height: 12rpx; margin-right: 10rpx; border-radius: 50%; background: #55b98c; box-shadow: 0 0 0 5rpx rgba(85,185,140,.12); }
.freshness.is-stale { color: #9a641e; }.freshness.is-stale::before { background: #e1a53c; box-shadow: 0 0 0 5rpx rgba(225,165,60,.14); }
.area-list { margin-top: 36rpx; }
.area-row { position: relative; display: grid; grid-template-columns: 62rpx 1fr auto 34rpx; align-items: center; gap: 14rpx; min-height: 130rpx; margin-bottom: 14rpx; padding: 20rpx 22rpx; border: 1rpx solid rgba(23,23,20,.1); border-radius: 26rpx; box-shadow: 0 4rpx 8rpx rgba(53,44,29,.05), 0 16rpx 30rpx rgba(53,44,29,.06), inset 0 2rpx 0 rgba(255,255,255,.65); }
.area-row:active { transform: translateX(5rpx); }
.area-number { font-family: serif; font-size: 25rpx; opacity: .45; }
.area-name { display: flex; flex-direction: column; }
.area-name text:first-child { font-family: "Songti SC", serif; font-size: 50rpx; }
.area-name text:last-child { margin-top: 2rpx; font-size: 17rpx; font-weight: 650; letter-spacing: 3rpx; }
.area-data { display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx; font-size: 20rpx; opacity: .7; }
.area-arrow { font-size: 30rpx; }
.tone-amber { background: linear-gradient(145deg, #ffe39a, #e9bd45); }
.tone-coral { background: linear-gradient(145deg, #f7d5cb, #e9a997); }
.tone-teal { background: linear-gradient(145deg, #d8ebe6, #9dc9bf); }
.tone-violet { background: linear-gradient(145deg, #e8e0f4, #c8b6df); }
.tone-cyan { background: linear-gradient(120deg, #d9edf0, #add4dd); }
.part-hero { position: relative; overflow: hidden; min-height: 300rpx; box-sizing: border-box; padding: 30rpx; border-radius: 12rpx 52rpx 52rpx 52rpx; box-shadow: 0 5rpx 8rpx rgba(53,44,29,.08), 0 26rpx 54rpx rgba(53,44,29,.12); }
.part-hero.is-turning { animation:archive-turn-away .15s ease-in forwards; }.notepad-card { animation:archive-turn-in .16s ease-out; }@keyframes archive-turn-away { to { opacity:.16; transform:rotateY(58deg); box-shadow:0 8rpx 16rpx rgba(53,44,29,.06); } }@keyframes archive-turn-in { from { opacity:.18; transform:rotateY(-12deg); } to { opacity:1; transform:rotateY(0); } }
.notepad-card { min-height:300rpx; }.notepad-card.is-flipping-back { animation:archive-turn-away .15s ease-in forwards; }.notepad-back-head { position:relative; z-index:1; display:flex; justify-content:space-between; align-items:flex-start; }.notepad-preview { position:relative; z-index:1; min-height:68rpx; margin-top:16rpx; color:#393328; font-size:23rpx; line-height:1.5; white-space:pre-wrap; }.notepad-card .notepad-actions { justify-content:space-between; gap:12rpx; margin-top:14rpx; font-size:18rpx; }.flip-hint { position:relative; z-index:1; padding-top:4rpx; border-top:1rpx solid rgba(23,23,20,.34); color:rgba(23,23,20,.62); font-size:16rpx; letter-spacing:2rpx; }.notepad-card .notepad-input { height:300rpx; max-height:42vh; overflow-y:auto; }.notepad-card:active .flip-hint { opacity:.65; }
.notepad-card .notepad-title { margin-top:3rpx; font-size:33rpx; line-height:1.1; }.notepad-card .eyebrow { font-size:15rpx; letter-spacing:2rpx; }.notepad-card .compact-input { height:142rpx; min-height:142rpx; max-height:142rpx; margin-top:10rpx; padding:8rpx 0; font-size:25rpx; }.notepad-card .notepad-status { margin-top:6rpx; font-size:15rpx; }
.part-hero::after { content: "ARCHIVE"; position: absolute; right: -8rpx; bottom: -26rpx; color: rgba(255,255,255,.3); font-family: serif; font-size: 78rpx; letter-spacing: 4rpx; }
.hero-top { position: relative; z-index: 1; display: flex; justify-content: space-between; }
.overview-link { padding-bottom: 4rpx; border-bottom: 1rpx solid currentColor; font-size: 21rpx; }
.part-title { position: relative; z-index: 1; margin-top: 20rpx; font-family: "Songti SC", serif; font-size: 96rpx; line-height: 1; }
.part-meta, .part-latest { position: relative; z-index: 1; margin-top: 14rpx; font-size: 23rpx; }
.part-latest { opacity: .68; }
.part-switch { width: calc(100% + 60rpx); margin: 18rpx -30rpx 0; white-space: nowrap; }
.part-switch-inner { display: inline-flex; gap: 10rpx; padding: 8rpx 30rpx 14rpx; }
.part-pill { min-width: 70rpx; padding: 16rpx 22rpx; border: 1rpx solid rgba(23,23,20,.12); border-radius: 999rpx; background: rgba(253,250,243,.8); text-align: center; font-size: 23rpx; }
.part-pill.active { font-weight: 650; box-shadow: 0 8rpx 18rpx rgba(53,44,29,.1); }
.sort-rail { display: flex; align-items: center; gap: 8rpx; margin-top: 6rpx; padding: 9rpx; border-radius: 18rpx; background: rgba(239,233,221,.72); }
.sort-label { margin: 0 5rpx; color: #817b72; font-size: 18rpx; letter-spacing: 2rpx; }
.sort-option { flex: 1; padding: 12rpx 6rpx; border-radius: 13rpx; text-align: center; color: #77736b; font-size: 19rpx; }
.sort-option.active { background: #171714; color: #f8f5ed; box-shadow: 0 5rpx 12rpx rgba(23,23,20,.13); }
.movement-list { margin-top: 28rpx; }
.list-heading { display: flex; align-items: flex-end; justify-content: space-between; padding: 0 4rpx 10rpx; }
.count { font-family: serif; font-size: 48rpx; color: #aaa297; }
.movement-card { margin-top: 18rpx; padding: 26rpx; border: 1rpx solid rgba(23,23,20,.11); border-radius: 26rpx 26rpx 8rpx 26rpx; background: rgba(253,250,243,.94); box-shadow: 0 3rpx 6rpx rgba(53,44,29,.04), 0 16rpx 36rpx rgba(53,44,29,.07), inset 0 2rpx 0 rgba(255,255,255,.88); }
.movement-card:active { transform: translateY(2rpx); box-shadow: 0 3rpx 7rpx rgba(53,44,29,.08); }
.movement-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 16rpx; }
.focus-mark { display:inline-block; margin-bottom:8rpx; color:#8a5a00; font-size:18rpx; font-weight:700; letter-spacing:.14em; }
.movement-name { font-family: "Songti SC", serif; font-size: 40rpx; line-height: 1.2; }
.movement-en { margin-top: 7rpx; color: #77736b; font-size: 20rpx; }
.session-badge { flex: none; padding: 8rpx 12rpx; border-radius: 999rpx; background: #eee7da; font-size: 19rpx; }
.latest-set { display: flex; justify-content: space-between; margin-top: 24rpx; padding-top: 18rpx; border-top: 1rpx solid rgba(23,23,20,.12); color: #77736b; font-size: 20rpx; letter-spacing: 1rpx; }
.set-summary { margin-top: 10rpx; font-size: 28rpx; line-height: 1.5; }
.compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10rpx; margin-top: 18rpx; }
.compare-cell { min-height: 82rpx; padding: 14rpx; border-radius: 16rpx; background: #f0eadf; }
.compare-label { color: #817b72; font-size: 17rpx; letter-spacing: 2rpx; }
.compare-value { margin-top: 7rpx; font-size: 21rpx; line-height: 1.45; }
.movement-note { margin-top: 16rpx; color: #6f6a62; font-size: 22rpx; }
.movement-action { margin-top: 20rpx; font-size: 23rpx; font-weight: 650; }
.session-list { position: relative; z-index: 1; margin-top: 28rpx; }
.session-card { margin-top: 16rpx; padding: 25rpx; border: 1rpx solid rgba(23,23,20,.11); border-radius: 8rpx 28rpx 28rpx 28rpx; background: rgba(253,250,243,.9); box-shadow: 0 4rpx 9rpx rgba(53,44,29,.05),0 18rpx 34rpx rgba(53,44,29,.07),inset 0 2rpx 0 rgba(255,255,255,.82); }
.session-card-head { display: flex; justify-content: space-between; align-items: baseline; padding-bottom: 15rpx; border-bottom: 1rpx solid rgba(23,23,20,.11); }
.session-card-head text:first-child { font-family: "Songti SC",serif; font-size: 35rpx; }.session-card-head text:last-child { color:#77736b; font-size:22rpx; }
.session-meta { display:flex; justify-content:space-between; margin-top:14rpx; color:#6f6a62; font-size:19rpx; }
.session-movement-chips { display:flex; flex-wrap:wrap; gap:9rpx; margin-top:16rpx; }
.session-movement-chips text { max-width:280rpx; overflow:hidden; padding:9rpx 13rpx; border:1rpx solid rgba(23,23,20,.1); border-radius:999rpx; background:rgba(255,255,255,.48); font-size:20rpx; text-overflow:ellipsis; white-space:nowrap; }
.session-full-summary { margin-top:16rpx; padding:14rpx 0; border-top:1rpx solid rgba(23,23,20,.11); white-space:pre-wrap; color:#37352f; font-size:22rpx; line-height:1.6; }
.session-movement-chips .related-movement { border-color:rgba(138,91,0,.35); background:rgba(255,218,110,.34); color:#6e4a00; }
.session-note { margin-top: 14rpx; padding-top: 14rpx; border-top: 1rpx dashed rgba(23,23,20,.12); color:#6f6a62; font-size:21rpx; line-height:1.55; }
