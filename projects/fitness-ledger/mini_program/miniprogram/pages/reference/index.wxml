<view class="page reference-page {{selected ? 'selected-theme tone-page-' + area.tone : ''}}">
  <image wx:if="{{selected}}" class="theme-art" src="/images/themes-v2/{{selected}}.webp" mode="aspectFill" />
  <block wx:if="{{!selected}}">
    <view class="eyebrow">BEFORE YOU TRAIN / READ ONLY</view>
    <view class="title">训练部位<br/>档案。</view>
    <view class="intro">不是训练计划。选择今天可能练的部位，快速回看动作、最近表现与历史轨迹。</view>
    <view wx:if="{{freshness}}" class="freshness {{freshness.stale ? 'is-stale' : ''}}">{{freshness.text}}</view>
    <view wx:if="{{loading}}" class="state">正在整理动作档案…</view>
    <view wx:elif="{{error}}" class="state error">{{error}}</view>
    <view wx:else class="area-list">
      <view wx:for="{{areas}}" wx:key="id" class="area-row tone-{{item.tone}}" data-part="{{item.id}}" bindtap="selectArea">
        <view class="area-number">0{{index + 1}}</view>
        <view class="area-name"><text>{{item.cn}}</text><text>{{item.en}}</text></view>
        <view class="area-data"><text>{{item.movement_count || 0}} 动作</text><text>{{item.session_count || 0}} 次训练</text></view>
        <view class="area-arrow">→</view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view wx:if="{{!notepadOpen}}" class="part-hero tone-{{area.tone}} {{notepadTurning ? 'is-turning' : ''}}" bindtap="toggleNotepad">
      <view class="hero-top"><view class="eyebrow">{{area.labelEn}} ARCHIVE</view><view class="flip-hint">FLIP</view></view>
      <view class="part-title">{{area.label}}</view>
      <view class="part-meta">{{area.session_count || 0}} 次训练 · {{area.movement_count || 0}} 个动作</view>
      <view class="part-latest">最近训练 {{area.latest_date || '暂无'}}</view>
    </view>
    <view wx:else class="notepad-sticky"><view class="part-hero notepad-card tone-{{area.tone}} {{notepadFlipBack ? 'is-flipping-back' : ''}}" catchtap="noop"><view class="notepad-back-head" bindtap="toggleNotepad"><view><view class="eyebrow">{{area.labelEn}} / LOCAL NOTE</view><view class="notepad-title">{{area.label}} / TEMP NOTE</view></view><view class="flip-hint">FLIP</view></view><block wx:if="{{!notepadExpanded}}"><view class="notepad-preview clamp-3">{{noteText || 'Tap expand to begin a freeform note.'}}</view><view class="notepad-actions"><view bindtap="copyNote">COPY ALL</view><view class="notepad-clear" bindtap="clearNote">CLEAR</view><view bindtap="expandNotepad">EXPAND EDIT</view></view></block><block wx:else><textarea class="notepad-input" value="{{noteText}}" bindinput="onNoteInput" placeholder="Freeform notes, any format." maxlength="-1" fixed="true"/><view class="notepad-actions"><view bindtap="copyNote">COPY ALL</view><view class="notepad-clear" bindtap="clearNote">CLEAR</view><view bindtap="collapseNotepad">COLLAPSE EDIT</view></view></block><view class="notepad-status">AUTOSAVED LOCALLY</view></view></view>
    <scroll-view scroll-x class="part-switch" enhanced show-scrollbar="false">
      <view class="part-switch-inner">
        <view wx:for="{{areas}}" wx:key="id" class="part-pill {{selected === item.id ? 'active tone-' + item.tone : ''}}" data-part="{{item.id}}" bindtap="selectArea">{{item.cn}}</view>
      </view>
    </scroll-view>
    <view class="sort-rail">
      <view class="sort-label">排序</view>
      <view class="sort-option {{sortBy === 'frequency' ? 'active' : ''}}" data-sort="frequency" bindtap="setSort">训练频率</view>
      <view class="sort-option {{sortBy === 'recent' ? 'active' : ''}}" data-sort="recent" bindtap="setSort">最近训练</view>
      <view class="sort-option {{sortBy === 'days' ? 'active' : ''}}" data-sort="days" bindtap="setSort">按训练日</view>
    </view>
    <view wx:if="{{loading}}" class="state">正在读取{{area.label || ''}}部档案…</view>
    <view wx:elif="{{error}}" class="state error">{{error}}</view>
    <view wx:elif="{{sortBy !== 'days' && !area.movements.length}}" class="state">该部位暂时没有动作历史。</view>
    <view wx:elif="{{sortBy === 'days' && !area.sessions.length}}" class="state">该部位暂时没有相关训练日。</view>
    <view wx:elif="{{sortBy !== 'days'}}" class="movement-list">
      <view class="list-heading"><view><view class="eyebrow">MOVEMENTS / FREQUENCY</view><view class="section-title">动作与最近表现</view></view><view class="count">{{area.movement_count}}</view></view>
      <view wx:for="{{area.movements}}" wx:key="movement_id" class="movement-card" data-id="{{item.movement_id}}" bindtap="openMovement">
        <view class="movement-head">
          <view><view wx:if="{{item.pinned}}" class="focus-mark">★ FOCUS</view><view class="movement-name">{{item.display_name}}</view><view class="movement-en">{{item.english_name}}</view></view>
          <view class="session-badge">{{item.sessions}} 次</view>
        </view>
        <view class="latest-set" wx:if="{{item.latest}}"><text>最近</text><text>{{item.latest.date}}{{item.latest.order ? ' · 第 ' + item.latest.order + ' 动作' : ''}}</text></view>
        <view class="set-summary clamp-2">{{item.latest.summary || '暂无组数记录'}}</view>
        <view class="compare-grid">
          <view class="compare-cell"><view class="compare-label">上一次</view><view class="compare-value clamp-2">{{item.previous ? item.previous.summary : '首次记录'}}</view></view>
          <view class="compare-cell"><view class="compare-label">历史最好</view><view class="compare-value">{{item.best && item.best.max_weight ? item.best.max_weight + ' kg' : (item.best && item.best.total_reps ? item.best.total_reps + ' reps' : '-')}}</view></view>
        </view>
        <view wx:if="{{item.latest.notes}}" class="movement-note clamp-2">{{item.latest.notes}}</view>
        <view class="movement-action">查看完整轨迹 →</view>
      </view>
    </view>
    <view wx:else class="session-list">
      <view class="list-heading"><view><view class="eyebrow">TRAINING DAYS / RECENT</view><view class="section-title">相关训练日</view></view><view class="count">{{area.sessions.length}}</view></view>
      <view wx:for="{{area.sessions}}" wx:key="id" class="session-card" data-date="{{item.date}}" bindtap="openSession">
        <view class="session-card-head"><text>{{item.date}}</text><text>{{item.title}}</text></view>
        <view class="session-meta"><text>{{item.related_count || 0}} 个相关动作</text><text>完整训练上下文</text></view>
        <view class="session-movement-chips">
          <text wx:for="{{item.related_movements}}" wx:for-item="movement" wx:key="*this" wx:if="{{index < 4}}" class="related-movement">{{movement}}</text>
        </view>
        <view class="session-full-summary clamp-3">{{item.full_summary}}</view>
        <view wx:if="{{item.notes}}" class="session-note clamp-2">{{item.notes}}</view>
        <view class="movement-action">查看当日训练 →</view>
      </view>
    </view>
  </block>
</view>
