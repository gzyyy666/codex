<view class="page"><view class="eyebrow">MOVEMENT / RECENT 5</view><view wx:if="{{loading}}" class="state">读取中…</view><view wx:elif="{{error}}" class="state error">{{error}}</view>
  <block wx:elif="{{movement}}"><view class="title">{{movement.display_name}}</view><view class="muted">{{movement.english_name}} · {{movement.muscle_group}}</view><view class="readonly">只读动作历史</view>
    <view><text wx:for="{{movement.aliases}}" wx:key="*this" class="chip">{{item}}</text></view>
    <view wx:if="{{!history.length}}" class="state">该动作暂无历史。</view>
    <view wx:for="{{history}}" wx:key="_id" class="card"><view class="eyebrow">{{item.date}}</view><view wx:for="{{item.sets}}" wx:key="index" class="row"><text>{{item.weight_text || item.weight || '自重'}}</text><text>{{item.reps}} × {{item.sets}}</text></view><view class="muted">{{item.notes}}</view></view>
  </block><view wx:else class="state">没有找到该动作。</view>
</view>
