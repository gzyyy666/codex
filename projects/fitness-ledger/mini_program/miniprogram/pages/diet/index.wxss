.diet-page { background: radial-gradient(circle at 0 12%, rgba(255,218,110,.12), transparent 30%), #f8f5ed; }
.diet-intro { color: #77736b; font-size: 24rpx; line-height: 1.55; }
.diet-slip { margin-top: 18rpx; padding: 26rpx; border: 1rpx solid rgba(91,70,34,.12); border-radius: 7rpx 28rpx 28rpx 28rpx; background: linear-gradient(145deg, #fff6d9, #f2dfaa); box-shadow: 0 3rpx 6rpx rgba(53,44,29,.05), 0 18rpx 38rpx rgba(53,44,29,.08), inset 0 2rpx 0 rgba(255,255,255,.55); }
.offset-1 { transform: rotate(-.25deg); background: linear-gradient(145deg, #f7eadb, #e7ceb7); }
.offset-2 { transform: rotate(.18deg); background: linear-gradient(145deg, #edf0da, #d4d9af); }
.diet-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 18rpx; }
.diet-date { margin-top: 7rpx; font-family: "Songti SC", serif; font-size: 34rpx; }
.diet-kcal { font-family: "Songti SC", serif; font-size: 48rpx; }
.diet-kcal text { margin-left: 5rpx; font-family: sans-serif; font-size: 18rpx; }
.macro-strip { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8rpx; margin-top: 20rpx; padding: 12rpx; border-top: 1rpx solid rgba(23,23,20,.12); border-bottom: 1rpx solid rgba(23,23,20,.12); }
.macro-strip view { display: flex; justify-content: center; gap: 8rpx; font-size: 21rpx; }
.macro-strip text:first-child { font-weight: 700; }
.diet-summary { margin-top: 17rpx; white-space: pre-wrap; font-size: 22rpx; color: #625b51; }
.diet-action { display: inline-flex; margin-top: 17rpx; padding: 9rpx 0 4rpx; border-bottom: 1rpx solid #171714; font-size: 21rpx; font-weight: 650; }
