<view class="page today-page">
  <view class="eyebrow">LATEST DAILY ARCHIVE</view><view class="title">最近一日。</view>
  <view wx:if="{{loading}}" class="state">读取中…</view><view wx:elif="{{error}}" class="state error">{{error}}</view>
  <block wx:elif="{{item}}">
    <view class="today-hero">
      <view class="eyebrow">{{item.date}}</view>
      <view class="today-weight">{{item.body['Weight (kg)'] || '-'}}<text>kg</text></view>
      <view class="today-split">{{item.body.Training || '休息日'}}</view>
      <view class="today-cardio clamp-2">{{item.body.Cardio || '无有氧记录'}}</view>
    </view>
    <view class="signal-grid nutrition-grid">
      <view class="signal"><view class="signal-label">CALORIES</view><view class="signal-value">{{item.diet['Calories (kcal)'] || '-'}}</view></view>
      <view class="signal"><view class="signal-label">PROTEIN</view><view class="signal-value">{{item.diet['Protein (g)'] || '-'}}g</view></view>
      <view class="signal"><view class="signal-label">CARBS</view><view class="signal-value">{{item.diet['Carbs (g)'] || '-'}}g</view></view>
      <view class="signal"><view class="signal-label">FAT</view><view class="signal-value">{{item.diet['Fat (g)'] || '-'}}g</view></view>
    </view>
    <view class="archive-slip food-slip">
      <view class="slip-head"><view><view class="eyebrow">FOOD NOTE</view><view class="section-title">饮食摘要</view></view><view class="expand" bindtap="toggleFood">{{showFood ? '收起' : '展开'}}</view></view>
      <view class="food-text {{showFood ? '' : 'clamp-3'}}">{{item.diet['Food Summary'] || '没有饮食摘要'}}</view>
    </view>
    <view class="button" bindtap="openRecord">查看完整记录</view>
  </block>
  <view wx:else class="state">云端尚无记录。</view>
</view>
