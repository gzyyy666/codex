.draft-status { display:flex; justify-content:space-between; align-items:flex-start; gap:18rpx; margin-top:22rpx; padding:18rpx 20rpx; border-radius:14rpx; background:#24241f; color:#f8f5ed; font-size:20rpx; line-height:1.5; }.draft-status text:last-child { color:#ffda6e; text-align:right; }.draft-note { margin:18rpx 6rpx 26rpx; color:#706b62; font-size:22rpx; line-height:1.65; }.draft-paper { padding:26rpx; border:1rpx solid rgba(23,23,20,.12); border-radius:10rpx 34rpx 34rpx 34rpx; background:#fcf9f2; box-shadow:0 4rpx 8rpx rgba(53,44,29,.06),0 20rpx 42rpx rgba(53,44,29,.08),inset 0 2rpx 0 #fff; }.field-label { color:#7d776d; font-size:18rpx; font-weight:700; letter-spacing:2rpx; }.theme-input { height:70rpx; margin-top:10rpx; border-bottom:1rpx solid rgba(23,23,20,.18); font-family:"Songti SC",serif; font-size:34rpx; }.exercise-heading { display:flex; justify-content:space-between; align-items:flex-end; margin-top:34rpx; }.exercise-count { color:#777168; font-size:21rpx; }.exercise-slip { margin-top:18rpx; padding:20rpx; border-radius:20rpx 20rpx 7rpx 20rpx; background:#f1ece1; }.exercise-top { display:flex; align-items:center; gap:14rpx; }.exercise-order { color:#8c6725; font-family:serif; font-size:28rpx; }.exercise-name { flex:1; min-width:0; font-size:28rpx; font-weight:650; }.delete,.order-tools text { color:#8b493d; font-size:20rpx; }.metric-row { display:grid; grid-template-columns:1fr 1fr 1fr; gap:10rpx; margin-top:18rpx; }.metric-row input,.notes-input { box-sizing:border-box; width:100%; padding:13rpx; border:1rpx solid rgba(23,23,20,.1); border-radius:8rpx; background:#fcf9f2; font-size:21rpx; }.notes-input { margin-top:10rpx; }.order-tools { display:flex; justify-content:flex-end; gap:26rpx; margin-top:16rpx; }.add-exercise { margin-top:22rpx; padding:20rpx; border:1rpx dashed rgba(23,23,20,.25); border-radius:15rpx; text-align:center; font-size:23rpx; }.clear-draft { margin:30rpx auto; width:max-content; padding-bottom:5rpx; border-bottom:1rpx solid #8b493d; color:#8b493d; font-size:21rpx; }
