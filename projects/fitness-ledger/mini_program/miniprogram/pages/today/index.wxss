.today-hero { margin-top: 26rpx; padding: 30rpx; border-radius: 12rpx 46rpx 46rpx 46rpx; color: #f8f5ed; background: radial-gradient(circle at 86% 16%, rgba(255,218,110,.2), transparent 38%), #1b1b18; box-shadow: 0 5rpx 8rpx rgba(0,0,0,.15), 0 24rpx 50rpx rgba(35,30,21,.16); }
.today-hero .eyebrow { color: rgba(248,245,237,.58); }
.today-weight { margin-top: 20rpx; font-family: "Songti SC", serif; font-size: 90rpx; line-height: 1; }
.today-weight text { margin-left: 8rpx; font-family: sans-serif; font-size: 24rpx; }
.today-split { margin-top: 25rpx; padding-top: 20rpx; border-top: 1rpx solid rgba(255,255,255,.2); font-size: 34rpx; }
.today-cardio { margin-top: 14rpx; color: rgba(248,245,237,.68); font-size: 23rpx; }
.nutrition-grid { margin-top: 16rpx; }
.food-slip { border-radius: 30rpx 8rpx 30rpx 30rpx; }
.slip-head { display: flex; align-items: flex-start; justify-content: space-between; }
.expand { padding: 10rpx 0 5rpx; border-bottom: 1rpx solid #171714; font-size: 21rpx; }
.food-text { margin-top: 20rpx; white-space: pre-wrap; font-size: 24rpx; line-height: 1.65; }
