<view class="page search-page"><view class="eyebrow">SEARCH THE ARCHIVE</view><view class="title">查动作，<br/>也查日期。</view>
  <view class="search-bar"><input class="input" placeholder="动作、日期、饮食或记录关键词" value="{{query}}" bindinput="onInput" confirm-type="search" bindconfirm="search"/><view class="search-button" bindtap="search">搜索</view></view>
  <view class="search-hint">支持动作名、英文名、别名、训练部位与日期。</view>
  <view wx:if="{{loading}}" class="state">搜索中…</view><view wx:elif="{{error}}" class="state error">{{error}}</view><view wx:elif="{{query && !results.length}}" class="state">没有找到相关记录。</view>
  <view wx:for="{{results}}" wx:key="id" data-index="{{index}}" bindtap="open" class="result-slip">
    <view class="result-type">{{item.type === 'movement' ? 'MOVEMENT' : 'ARCHIVE'}} {{item.date || ''}}</view>
    <view class="result-title">{{item.title}}</view><view class="result-subtitle">{{item.subtitle}}</view><view class="result-preview clamp-2">{{item.preview}}</view><view class="result-open">查看 →</view>
  </view>
</view>
