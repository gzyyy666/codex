.search-bar { display: grid; grid-template-columns: 1fr 126rpx; gap: 10rpx; margin-top: 30rpx; }
.search-button { display: flex; align-items: center; justify-content: center; border-radius: 18rpx; background: #171714; color: #f8f5ed; font-size: 23rpx; font-weight: 650; }
.search-button:active { transform: scale(.98); }
.search-hint { margin: 15rpx 4rpx 0; color: #8a847b; font-size: 20rpx; }
.result-slip { position: relative; margin-top: 18rpx; padding: 24rpx 26rpx; border: 1rpx solid rgba(23,23,20,.1); border-radius: 24rpx 24rpx 6rpx 24rpx; background: rgba(253,250,243,.93); box-shadow: 0 3rpx 6rpx rgba(53,44,29,.04), 0 15rpx 32rpx rgba(53,44,29,.06); }
.result-type { color: #8b857c; font-size: 17rpx; font-weight: 650; letter-spacing: 3rpx; }
.result-title { margin-top: 12rpx; font-family: "Songti SC", serif; font-size: 37rpx; line-height: 1.25; }
.result-subtitle { margin-top: 6rpx; color: #6f6a62; font-size: 21rpx; }
.result-preview { margin-top: 14rpx; color: #77736b; font-size: 22rpx; }
.result-open { margin-top: 16rpx; font-size: 22rpx; font-weight: 650; }
