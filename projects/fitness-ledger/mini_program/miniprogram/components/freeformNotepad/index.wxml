<view class="notepad-dock"><view wx:if="{{!open}}" class="notepad-dock-bar" bindtap="toggle"><view><text>TRAINING NOTE</text><text class="notepad-dock-saved"> · 已自动保存</text></view><text>展开</text></view><view wx:else class="notepad-dock-card"><view class="notepad-dock-head"><view><view class="eyebrow">LOCAL ONLY</view><view class="notepad-dock-title">TRAINING NOTE / 训练记录</view></view><view class="notepad-collapse" bindtap="toggle">收拢</view></view><textarea class="notepad-dock-input" value="{{text}}" bindinput="onInput" placeholder="自由记录本次训练，支持任意格式……" maxlength="-1" fixed="true"/><view class="notepad-dock-actions"><view bindtap="copy">复制全部</view><view class="notepad-dock-clear" bindtap="clear">清空</view></view><view class="notepad-dock-status">已自动保存到本地</view></view></view>
