:host { position:fixed; top:calc(env(safe-area-inset-top) + 14rpx); right:22rpx; left:22rpx; z-index:20; pointer-events:none; animation:dock-enter .16s ease-out; }.notepad-dock { pointer-events:auto; }.notepad-dock-bar { display:flex; align-items:center; justify-content:space-between; padding:16rpx 20rpx; border:1rpx solid rgba(55,51,43,.18); border-radius:999rpx; background:rgba(252,249,242,.97); box-shadow:0 8rpx 22rpx rgba(53,44,29,.15); color:#302d27; font-size:20rpx; }.notepad-dock-saved { color:#8a6a14; }.notepad-dock-card { max-height:66vh; padding:22rpx; border:1rpx solid rgba(55,51,43,.2); border-radius:12rpx 30rpx 30rpx 30rpx; background:#fcf9f2; box-shadow:0 12rpx 34rpx rgba(53,44,29,.18); }.notepad-dock-head { display:flex; justify-content:space-between; align-items:flex-start; }.notepad-dock-title { margin-top:4rpx; font-family:"Songti SC",serif; font-size:36rpx; }.notepad-collapse { padding-bottom:4rpx; border-bottom:1rpx solid currentColor; font-size:20rpx; }.notepad-dock-input { display:block; box-sizing:border-box; width:100%; height:300rpx; max-height:42vh; margin-top:16rpx; padding:12rpx 0; border-top:1rpx solid rgba(23,23,20,.18); border-bottom:1rpx solid rgba(23,23,20,.12); background:transparent; color:#27251f; font-size:24rpx; line-height:1.55; }.notepad-dock-actions { display:flex; gap:28rpx; margin-top:14rpx; font-size:20rpx; font-weight:650; }.notepad-dock-clear { color:#8b493d; }.notepad-dock-status { margin-top:9rpx; color:rgba(23,23,20,.55); font-size:17rpx; }@keyframes dock-enter { from { opacity:0; transform:translateY(-10rpx); } to { opacity:1; transform:translateY(0); } }
