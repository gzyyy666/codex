:host { position:fixed; top:calc(env(safe-area-inset-top) + 14rpx); right:22rpx; left:22rpx; z-index:20; pointer-events:none; }.notepad-dock { pointer-events:auto; }.notepad-dock-bar { display:flex; align-items:center; justify-content:space-between; padding:16rpx 20rpx; border:1rpx solid rgba(84,64,22,.2); border-radius:999rpx; background:rgba(255,227,154,.96); box-shadow:0 8rpx 22rpx rgba(53,44,29,.15); color:#302817; font-size:20rpx; }.notepad-dock-card { max-height:66vh; padding:22rpx; border:1rpx solid rgba(84,64,22,.22); border-radius:12rpx 30rpx 30rpx 30rpx; background:linear-gradient(145deg,#ffe39a,#e9bd45); box-shadow:0 12rpx 34rpx rgba(53,44,29,.22); animation:dock-open .16s ease-out; }.notepad-dock-head { display:flex; justify-content:space-between; align-items:flex-start; }.notepad-dock-title { margin-top:4rpx; font-family:"Songti SC",serif; font-size:36rpx; }.notepad-collapse { padding-bottom:4rpx; border-bottom:1rpx solid currentColor; font-size:20rpx; }.notepad-dock-input { display:block; box-sizing:border-box; width:100%; height:300rpx; max-height:42vh; margin-top:16rpx; padding:12rpx 0; border-top:1rpx solid rgba(23,23,20,.18); border-bottom:1rpx solid rgba(23,23,20,.12); background:transparent; color:#27251f; font-size:24rpx; line-height:1.55; }.notepad-dock-actions { display:flex; gap:28rpx; margin-top:14rpx; font-size:20rpx; font-weight:650; }.notepad-dock-clear { color:#8b493d; }.notepad-dock-status { margin-top:9rpx; color:rgba(23,23,20,.55); font-size:17rpx; }@keyframes dock-open { from { opacity:.2; transform:translateY(-10rpx); } to { opacity:1; transform:translateY(0); } }
.notepad-dock.tone-coral .notepad-dock-bar,.notepad-dock.tone-coral .notepad-dock-card { background:linear-gradient(145deg,#f7d5cb,#e9a997); }.notepad-dock.tone-teal .notepad-dock-bar,.notepad-dock.tone-teal .notepad-dock-card { background:linear-gradient(145deg,#d8ebe6,#9dc9bf); }.notepad-dock.tone-violet .notepad-dock-bar,.notepad-dock.tone-violet .notepad-dock-card { background:linear-gradient(145deg,#e8e0f4,#c8b6df); }.notepad-dock.tone-cyan .notepad-dock-bar,.notepad-dock.tone-cyan .notepad-dock-card { background:linear-gradient(120deg,#d9edf0,#add4dd); }
