page {
  --paper: #f8f5ed;
  --paper-light: #fdfaf3;
  --paper-deep: #efe9dd;
  --ink: #171714;
  --graphite: #77736b;
  --line: rgba(23, 23, 20, .12);
  --amber: #ffda6e;
  background: var(--paper);
  color: var(--ink);
  font-family: "PingFang SC", "Microsoft YaHei UI", sans-serif;
}
.page { min-height: 100vh; box-sizing: border-box; padding: 34rpx 30rpx 104rpx; }
.eyebrow { font-size: 19rpx; font-weight: 600; letter-spacing: 5rpx; color: var(--graphite); }
.title { margin: 16rpx 0 10rpx; font-family: "Songti SC", serif; font-size: 66rpx; font-weight: 400; line-height: 1.03; letter-spacing: -2rpx; }
.section-title { font-family: "Songti SC", serif; font-size: 38rpx; line-height: 1.15; }
.muted { color: var(--graphite); font-size: 24rpx; line-height: 1.55; }
.readonly { display: inline-flex; margin: 18rpx 0; padding: 9rpx 17rpx; border-radius: 999rpx; background: var(--ink); color: var(--paper); font-size: 18rpx; letter-spacing: 2rpx; }
.card, .archive-slip { margin-top: 20rpx; padding: 26rpx; border: 1rpx solid var(--line); border-radius: 26rpx; background: rgba(253,250,243,.94); box-shadow: 0 3rpx 6rpx rgba(53,44,29,.04), 0 18rpx 40rpx rgba(53,44,29,.06), inset 0 1rpx 0 rgba(255,255,255,.9); }
.metric { font-family: "Songti SC", serif; font-size: 58rpx; font-variant-numeric: tabular-nums; }
.row { display: flex; justify-content: space-between; gap: 20rpx; padding: 17rpx 0; border-bottom: 1rpx solid var(--line); }
.row:last-child { border-bottom: 0; }
.button { margin-top: 20rpx; padding: 22rpx 24rpx; border: 1rpx solid rgba(145,104,12,.22); border-radius: 20rpx; background: linear-gradient(180deg, #ffe38e, #f6c94d); box-shadow: 0 4rpx 7rpx rgba(106,73,8,.12), 0 13rpx 28rpx rgba(106,73,8,.12), inset 0 2rpx 0 rgba(255,255,255,.7); text-align: center; font-weight: 650; }
.button:active { transform: translateY(2rpx); box-shadow: 0 2rpx 3rpx rgba(106,73,8,.14), inset 0 1rpx 3rpx rgba(106,73,8,.08); }
.button.secondary { background: linear-gradient(180deg, #fffdf8, #f2ece1); border-color: var(--line); box-shadow: 0 3rpx 8rpx rgba(53,44,29,.05), inset 0 2rpx 0 rgba(255,255,255,.9); }
.input { box-sizing: border-box; width: 100%; height: 78rpx; padding: 0 24rpx; border: 1rpx solid rgba(23,23,20,.16); border-radius: 18rpx; background: rgba(255,253,247,.92); box-shadow: inset 0 2rpx 4rpx rgba(53,44,29,.04), 0 8rpx 22rpx rgba(53,44,29,.04); }
.state { margin-top: 64rpx; padding: 0 34rpx; text-align: center; color: var(--graphite); line-height: 1.7; }
.error { color: #9f352d; }
.chip { display: inline-block; margin: 8rpx 10rpx 0 0; padding: 9rpx 15rpx; border: 1rpx solid rgba(23,23,20,.08); border-radius: 999rpx; background: #eee7da; font-size: 21rpx; }
.clamp-2 { display: -webkit-box; overflow: hidden; -webkit-box-orient: vertical; -webkit-line-clamp: 2; line-height: 1.55; }
.clamp-3 { display: -webkit-box; overflow: hidden; -webkit-box-orient: vertical; -webkit-line-clamp: 3; line-height: 1.55; }
.text-link { display: inline-flex; margin-top: 18rpx; padding: 10rpx 0 5rpx; border-bottom: 2rpx solid var(--ink); font-size: 23rpx; font-weight: 600; }
.signal-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12rpx; }
.signal { padding: 18rpx; border-radius: 18rpx; background: rgba(239,233,221,.72); }
.signal-label { color: var(--graphite); font-size: 18rpx; letter-spacing: 2rpx; }
.signal-value { margin-top: 7rpx; font-family: "Songti SC", serif; font-size: 34rpx; font-variant-numeric: tabular-nums; }
