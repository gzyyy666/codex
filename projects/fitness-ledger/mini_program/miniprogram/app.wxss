page { background: #f6f1e7; color: #171714; font-family: "PingFang SC", sans-serif; }
.page { padding: 36rpx 30rpx 80rpx; }
.eyebrow { font-size: 20rpx; letter-spacing: 5rpx; color: #77736b; }
.title { margin: 18rpx 0 10rpx; font-family: serif; font-size: 64rpx; line-height: 1.05; }
.muted { color: #77736b; font-size: 26rpx; line-height: 1.6; }
.readonly { display: inline-flex; margin: 24rpx 0; padding: 10rpx 18rpx; border-radius: 999rpx; background: #171714; color: #f8f4ea; font-size: 20rpx; letter-spacing: 2rpx; }
.card { margin-top: 24rpx; padding: 28rpx; border: 1rpx solid rgba(23,23,20,.14); border-radius: 28rpx; background: rgba(255,253,247,.86); box-shadow: 0 16rpx 36rpx rgba(53,44,29,.07); }
.metric { font-family: serif; font-size: 58rpx; }
.row { display: flex; justify-content: space-between; gap: 20rpx; padding: 18rpx 0; border-bottom: 1rpx solid rgba(23,23,20,.1); }
.button { margin-top: 22rpx; padding: 24rpx; border-radius: 999rpx; background: #f2c94c; text-align: center; font-weight: 600; }
.button.secondary { background: #fffaf0; border: 1rpx solid rgba(23,23,20,.18); }
.input { box-sizing: border-box; width: 100%; padding: 22rpx 26rpx; border: 1rpx solid rgba(23,23,20,.2); border-radius: 999rpx; background: #fffaf0; }
.state { margin-top: 70rpx; text-align: center; color: #77736b; line-height: 1.7; }
.error { color: #9f352d; }
.chip { display: inline-block; margin: 8rpx 10rpx 0 0; padding: 10rpx 16rpx; border-radius: 999rpx; background: #eee7da; font-size: 22rpx; }
.long { max-height: 220rpx; overflow: hidden; line-height: 1.65; }
